<%- include('navbar') %>
    <div class="container mt-4 mb-5">
        <div class="row bg-white p-4 rounded shadow-sm">
            <div class="col-md-5 text-center">
                <img id="anhChinh" src="<%= dienthoai.HinhAnh %>" alt="<%= dienthoai.TenDT %>" class="img-fluid rounded" style="max-height: 500px; object-fit: contain;">
            </div>

            <div class="col-md-7">
                <h2 class="fw-bold"><%= dienthoai.TenDT %></h2>
                <p class="text-muted">Hãng sản xuất: <span class="fw-bold text-dark"><%= dienthoai.HangSanXuat ? dienthoai.HangSanXuat.TenHang : 'Đang cập nhật' %></span></p>

                <div class="bg-light p-3 rounded mb-3">
                    <h3 id="giaHienThi" class="text-danger fw-bold mb-0">Vui lòng chọn phiên bản</h3>
                    <small id="trangThaiKho" class="text-muted mt-1 d-block"></small>
                </div>

                <div id="duLieuPhienBan" data-json="<%= JSON.stringify(dienthoai.CacPhienBan || []) %>" style="display: none;"></div>

                <div class="mb-3">
                    <label class="fw-bold mb-2">Chọn dung lượng:</label>
                    <div id="khuVucDungLuong" class="d-flex flex-wrap gap-2">
                        </div>
                </div>

                <div class="mb-4">
                    <label class="fw-bold mb-2">Chọn màu:</label>
                    <div id="khuVucMauSac" class="d-flex flex-wrap gap-2">
                        </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-success flex-grow-1 fw-bold py-2" id="btnMuaNgay" disabled>
                        MUA NGAY
                    </button>
                    <button class="btn btn-danger flex-grow-1 fw-bold py-2" id="btnThemGioHang" disabled>
                        <i class="bi bi-cart-plus"></i> THÊM VÀO GIỎ HÀNG
                    </button>
                </div>
                <div class="mt-2 text-center">
                    <a href="/" class="btn btn-light w-100 border">Quay lại trang chủ</a>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12 bg-white p-4 rounded shadow-sm">
                <h4 class="fw-bold border-bottom pb-2">Mô tả chi tiết</h4>
                <p style="white-space: pre-line;"><%= dienthoai.MoTa %></p>
            </div>
        </div>
    </div>

    <script>
        // 1. Lấy dữ liệu và các phần tử
        const theDuLieu = document.getElementById('duLieuPhienBan').getAttribute('data-json');
        const danhSachPhienBan = JSON.parse(theDuLieu);

        const khuVucDungLuong = document.getElementById('khuVucDungLuong');
        const khuVucMauSac = document.getElementById('khuVucMauSac');
        const giaHienThi = document.getElementById('giaHienThi');
        const trangThaiKho = document.getElementById('trangThaiKho');
        const anhChinh = document.getElementById('anhChinh');
        
        const btnMuaNgay = document.getElementById('btnMuaNgay');
        const btnThemGioHang = document.getElementById('btnThemGioHang');
        const linkAnhGoc = anhChinh.src;

        let dungLuongDangChon = null;
        let mauSacDangChon = null;

        const cacDungLuong = [...new Set(danhSachPhienBan.map(pb => pb.DungLuong))];

        function veNutDungLuong() {
            khuVucDungLuong.innerHTML = '';
            cacDungLuong.forEach(dl => {
                const btn = document.createElement('button');
                btn.className = `btn btn-sm ${dl === dungLuongDangChon ? 'btn-danger' : 'btn-outline-secondary'}`;
                btn.innerText = dl;
                btn.onclick = () => {
                    dungLuongDangChon = dl;
                    mauSacDangChon = null; 
                    veNutDungLuong();
                    veNutMauSac();
                    capNhatGiaTien();
                };
                khuVucDungLuong.appendChild(btn);
            });
        }

        function veNutMauSac() {
            khuVucMauSac.innerHTML = '';
            if (!dungLuongDangChon) return;

            const cacMauCuaDungLuong = danhSachPhienBan
                .filter(pb => pb.DungLuong.trim() === dungLuongDangChon.trim())
                .map(pb => pb.MauSac);

            cacMauCuaDungLuong.forEach(mau => {
                const btn = document.createElement('button');
                btn.className = `btn btn-sm ${mau === mauSacDangChon ? 'btn-primary' : 'btn-outline-primary'}`;
                btn.innerText = mau;
                btn.onclick = () => {
                    mauSacDangChon = mau;
                    veNutMauSac();
                    capNhatGiaTien();
                };
                khuVucMauSac.appendChild(btn);
            });
        }

        function capNhatGiaTien() {
            if (!dungLuongDangChon || !mauSacDangChon) {
                giaHienThi.innerText = "Vui lòng chọn Dung lượng và Màu sắc";
                btnMuaNgay.disabled = true;
                btnThemGioHang.disabled = true;
                return;
            }

            // Tìm phiên bản (Dùng trim để loại bỏ khoảng trắng dư thừa)
            const phienBanChinhXac = danhSachPhienBan.find(
                pb => pb.DungLuong.trim() === dungLuongDangChon.trim() && 
                      pb.MauSac.trim() === mauSacDangChon.trim()
            );

            if (phienBanChinhXac) {
                giaHienThi.innerText = Number(phienBanChinhXac.GiaBan).toLocaleString('vi-VN') + ' VNĐ';
                
                if (phienBanChinhXac.HinhAnhPhienBan) {
                    anhChinh.src = phienBanChinhXac.HinhAnhPhienBan;
                } else {
                    anhChinh.src = linkAnhGoc;
                }

                // 🔥 QUAN TRỌNG: Mở khóa nút bấm
                let tonKho = parseInt(phienBanChinhXac.SoLuongTon) || 0;
                if (tonKho > 0) {
                    trangThaiKho.innerHTML = `<i class="bi bi-check-circle-fill text-success"></i> Còn hàng (${tonKho} sản phẩm)`;
                    btnMuaNgay.disabled = false;     // Gỡ bỏ disabled
                    btnThemGioHang.disabled = false; // Gỡ bỏ disabled
                } else {
                    trangThaiKho.innerHTML = `<i class="bi bi-x-circle-fill text-danger"></i> Tạm hết hàng`;
                    btnMuaNgay.disabled = true;
                    btnThemGioHang.disabled = true;
                }
            }
        }

        // 🔥 XỬ LÝ SỰ KIỆN BẤM NÚT
        function xuLyThemGioHang(laMuaNgay = false) {
            const phienBan = danhSachPhienBan.find(
                pb => pb.DungLuong === dungLuongDangChon && pb.MauSac === mauSacDangChon
            );

            const data = {
                idDT: '<%= dienthoai._id %>',
                TenDT: '<%= dienthoai.TenDT %>',
                DungLuong: dungLuongDangChon,
                MauSac: mauSacDangChon,
                GiaBan: phienBan.GiaBan,
                HinhAnh: phienBan.HinhAnhPhienBan || linkAnhGoc
            };

            fetch('/giohang/them', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(resData => {
                if (resData.success) {
                    document.getElementById('cart-badge').innerText = resData.tongSoLuong;
                    if (laMuaNgay) {
                        window.location.href = '/giohang'; // Mua ngay thì chuyển trang luôn
                    } else {
                        alert('Đã thêm vào giỏ hàng thành công!');
                    }
                }
            });
        }

        btnThemGioHang.onclick = () => xuLyThemGioHang(false);
        btnMuaNgay.onclick = () => xuLyThemGioHang(true);

        // Khởi tạo
        if (cacDungLuong.length > 0) {
            dungLuongDangChon = cacDungLuong[0];
            veNutDungLuong();
            veNutMauSac();
            const mauDau = danhSachPhienBan.find(p => p.DungLuong === dungLuongDangChon);
            if(mauDau) mauSacDangChon = mauDau.MauSac;
            veNutMauSac();
            capNhatGiaTien();
        }
    </script>