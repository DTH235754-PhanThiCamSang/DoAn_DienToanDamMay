
<%- include('navbar') %>

<script id="data-phienban" type="application/json">
    <%- JSON.stringify(dienthoai.CacPhienBan || []) %>
</script>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-5">
            <div class="text-center mb-4 card shadow-sm p-3">
                <img src="<%= dienthoai.HinhAnh %>" class="img-fluid rounded" alt="Product">
            </div>

            <div class="card shadow-sm p-3">
                <h5 class="fw-bold border-bottom pb-2">Mô tả chi tiết:</h5>
                <div id="descriptionContent" class="description-collapsed">
                    <%- dienthoai.MoTa %>
                </div>
                <button id="btnToggleDesc" class="btn btn-link p-0 text-decoration-none mt-2">Xem thêm ▼</button>
            </div>
        </div>

        <div class="col-md-7 px-4">
            <h1 class="fw-bold" id="productTitle">
                <%= dienthoai.TenDT %>
            </h1>
            <p class="text-muted">Hãng: <strong>
                    <%= dienthoai.HangSanXuat ? dienthoai.HangSanXuat.TenHang : 'Chưa cập nhật' %>
                </strong></p>

            <div id="priceArea">
                <h3 class="text-danger fw-bold my-3" id="hienThiGia">Đang tính toán giá...</h3>
                <p id="giaGocArea" class="text-decoration-line-through text-muted small mb-3" style="display:none;">
                </p>
            </div>

            <div class="mb-4">
                <label class="fw-bold small d-block mb-2">Chọn dung lượng:</label>
                <div class="d-flex gap-2" id="dungLuongGroup">
                    <% let dsDL=[...new Set((dienthoai.CacPhienBan || []).map(p=> p.DungLuong))];
                        dsDL.forEach((dl, index) => {
                        %>
                        <button
                            class="btn <%= index === 0 ? 'btn-primary' : 'btn-outline-primary' %> px-4 variant-btn"
                            data-type="dungluong" data-value="<%= dl %>">
                            <%= dl %>
                        </button>
                        <% }) %>
                </div>
            </div>

            <div class="mb-4">
                <label class="fw-bold small d-block mb-2">Chọn màu:</label>
                <div class="d-flex gap-2" id="mauSacGroup">
                    <% let dsMau=[...new Set((dienthoai.CacPhienBan || []).map(p=> p.MauSac))];
                        dsMau.forEach((mau, index) => {
                        %>
                        <button
                            class="btn btn-light border rounded-pill px-3 py-1 variant-btn <%= index === 0 ? 'border-primary border-2 fw-bold text-primary' : '' %>"
                            data-type="mausac" data-value="<%= mau %>">
                            <%= mau %>
                        </button>
                        <% }) %>
                </div>
            </div>

            <hr>

            <div class="d-flex gap-2 mt-3">
                <button id="btnMuaNgay" data-id="<%= dienthoai._id %>"
                    class="btn btn-success fw-bold px-4 py-2 flex-grow-1">
                    MUA NGAY
                </button>

                <button id="btnThemVaoGio" data-id="<%= dienthoai._id %>"
                    class="btn btn-danger fw-bold px-4 py-2 flex-grow-1">
                    <i class="bi bi-cart-plus"></i> THÊM VÀO GIỎ HÀNG
                </button>
            </div>

            <div class="mt-3">
                <a href="/" class="btn btn-light w-100 border">Quay lại trang chủ</a>
            </div>
        </div>
    </div>
</div>

<style>
    .description-collapsed {
        max-height: 250px;
        overflow: hidden;
        position: relative;
        transition: max-height 0.4s ease;
    }

    .description-collapsed::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 60px;
        background: linear-gradient(transparent, white);
    }

    .description-expanded {
        max-height: 5000px;
    }

    .description-expanded::after {
        display: none;
    }
</style>
<script>
    const SP_TEN_GOC = "<%= dienthoai.TenDT %>";
    const SP_GIA_NHAP = Number("<%= dienthoai.GiaNhap || 0 %>");
</script>
<script src="/script.js"></script>