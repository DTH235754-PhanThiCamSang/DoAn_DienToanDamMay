    </a>
    <a href="/phieunhap" class="list-group-item list-group-item-action py-3 fw-bold <%= typeof active !== 'undefined' && active === 'phieunhap' ? 'active' : 'text-dark' %>">
        <i class="bi bi-file-earmark-arrow-down me-2"></i> Quản lý Phiếu nhập
    </a>
    <a href="/taikhoan" class="list-group-item list-group-item-action py-3 fw-bold <%= typeof active !== 'undefined' && active === 'taikhoan' ? 'active' : 'text-dark' %>">
