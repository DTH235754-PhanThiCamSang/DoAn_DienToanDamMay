<div class="list-group list-group-flush rounded shadow-sm bg-white">
    <div class="bg-dark text-white text-center py-3 fw-bold rounded-top">
        <i class="bi bi-shield-lock me-2"></i> ADMIN PANEL
    </div>
    
    <a href="/dienthoai" class="list-group-item list-group-item-action py-3 fw-bold <%= typeof active !== 'undefined' && active === 'sanpham' ? 'active' : 'text-dark' %>">
