<%- include('navbar') %>

    <div class="container mt-4 mb-5">
        <h3 class="mb-4 text-primary fw-bold text-uppercase">
            <i class="bi bi-phone-fill me-2"></i>Thêm Điện Thoại Mới
        </h3>

        <form action="/dienthoai/them" method="POST" enctype="multipart/form-data">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-info-circle me-1"></i> THÔNG TIN CHUNG
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Tên điện thoại (Từ phiếu nhập)</label>
                            <input class="form-control" list="listMayDaNhap" name="TenDT"
                                placeholder="Chọn hoặc nhập tên máy..." required>
                            <datalist id="listMayDaNhap">
                                <% dsMayTrongKho.forEach(ten=> { %>
                                    <option value="<%= ten %>">
                                        <% }) %>
                            </datalist>
                            <small class="text-muted">Gợi ý từ các máy đã có phiếu nhập kho</small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Hãng sản xuất</label>
                            <select name="HangSanXuat" class="form-select" required>
                                <option value="">-- Chọn hãng --</option>
                                <% hang.forEach(h=> { %>
                                    <option value="<%= h._id %>">
                                        <%= h.TenHang %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-success">Lợi nhuận mong muốn (%)</label>
                            <input type="number" name="PhanTramLoi" class="form-control" value="10" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-danger">Khuyến mãi / Giảm giá (%)</label>
                            <input type="number" name="PhanTramGiamGia" class="form-control" value="0">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Hình ảnh chính (Chọn từ máy)</label>
                        <input type="file" name="HinhAnh" class="form-control" accept="image/*" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả sản phẩm</label>
                        <textarea name="MoTa" class="form-control" rows="3"
                            placeholder="Thông số kỹ thuật..."></textarea>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div
                    class="card-header bg-success text-white fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-box-seam me-1"></i> CÁC PHIÊN BẢN SẢN PHẨM</span>
                    <button type="button" class="btn btn-sm btn-light text-success fw-bold" onclick="themPhienBan()">
                        <i class="bi bi-plus-circle"></i> Thêm phiên bản
                    </button>
                </div>
                <div class="card-body bg-light" id="khu-vuc-phien-ban">
                    <div class="border border-success bg-white rounded p-3 mb-3 position-relative phienban-item">
                        <div class="row">
                            <div class="col-md-3 mb-2">
                                <label class="small text-muted fw-bold">Dung lượng</label>
                                <input type="text" name="DungLuong[]" class="form-control" placeholder="128GB" required>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="small text-muted fw-bold">Màu sắc</label>
                                <input type="text" name="MauSac[]" class="form-control" placeholder="Titan" required>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="small text-muted fw-bold">Số lượng tồn</label>
                                <input type="number" name="SoLuongTon[]" class="form-control" value="0" required>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="small text-muted fw-bold">Link Ảnh bản này</label>
                                <input type="text" name="HinhAnhPhienBan[]" class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="small text-muted fw-bold text-primary">Giá nhập (VNĐ)</label>
                                <input type="number" name="GiaNhap[]" class="form-control border-primary" required>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-end mb-5">
                <a href="/dienthoai" class="btn btn-secondary me-2 px-4">Hủy</a>
                <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">
                    <i class="bi bi-save me-2"></i>Lưu Sản Phẩm
                </button>
            </div>
        </form>
    </div>

    <script>
        function themPhienBan() {
            const html = `
            <div class="border border-success bg-white rounded p-3 mb-3 position-relative phienban-item">
                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2 shadow-sm" onclick="this.closest('.phienban-item').remove()">
                    <i class="bi bi-trash"></i>
                </button>
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <label class="small text-muted fw-bold">Dung lượng</label>
                        <input type="text" name="DungLuong[]" class="form-control" placeholder="128GB" required>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="small text-muted fw-bold">Màu sắc</label>
                        <input type="text" name="MauSac[]" class="form-control" placeholder="Màu" required>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="small text-muted fw-bold">Số lượng tồn</label>
                        <input type="number" name="SoLuongTon[]" class="form-control" value="0" required>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="small text-muted fw-bold">Link Ảnh bản này</label>
                        <input type="text" name="HinhAnhPhienBan[]" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="small text-muted fw-bold text-primary">Giá nhập (VNĐ)</label>
                        <input type="number" name="GiaNhap[]" class="form-control border-primary" required>
                    </div>
                </div>
            </div>
        `;
            document.getElementById('khu-vuc-phien-ban').insertAdjacentHTML('beforeend', html);
        }
    </script>

    <%- include('footer') %>