<%- include('navbar') %>
    <div class="container mt-5 mb-5">
        <div class="card col-md-6 mx-auto shadow border-0">
            <div class="card-header bg-success text-white fw-bold fs-5">
                <i class="bi bi-person-plus-fill"></i> THÊM TÀI KHOẢN MỚI
            </div>
            <div class="card-body bg-light p-4">
                
                <form action="/taikhoan/them" method="POST">
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Tên đăng nhập</label>
                        <input type="text" name="TenDangNhap" class="form-control border-primary" placeholder="Nhập ID hoặc tên đăng nhập viết liền không dấu..." required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-danger">Mật khẩu</label>
                        <input type="password" name="MatKhau" class="form-control border-danger" placeholder="Nhập mật khẩu..." required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Họ và tên</label>
                        <input type="text" name="HoVaTen" class="form-control border-primary" placeholder="Nhập họ và tên người dùng..." required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Địa chỉ Email</label>
                        <input type="email" name="Email" class="form-control border-primary" placeholder="Nhập email..." required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-success">Cấp Quyền Hạn</label>
                        <select name="QuyenHan" class="form-select border-success fw-bold" required>
                            <option value="user" selected>Khách hàng (User)</option>
                            <option value="banhang">Nhân viên Bán hàng</option>
                            <option value="thukho">Nhân viên Thủ kho</option>
                            <option value="admin">Quản trị viên (Admin)</option>
                        </select>
                    </div>

                    <div class="text-center mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-success px-5 fw-bold"><i class="bi bi-check-circle"></i> Tạo Tài Khoản</button>
                        <a href="/taikhoan" class="btn btn-secondary px-4 ms-2"><i class="bi bi-arrow-left"></i> Quay lại</a>
                    </div>
                    
                </form>

            </div>
        </div>
    </div>