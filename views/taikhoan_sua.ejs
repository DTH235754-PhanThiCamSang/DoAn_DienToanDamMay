<%- include('navbar') %>
    <div class="container mt-5 mb-5">
        <div class="card col-md-6 mx-auto shadow border-0">
            <div class="card-header bg-warning text-dark fw-bold fs-5">
                <i class="bi bi-person-lines-fill"></i> SỬA THÔNG TIN TÀI KHOẢN
            </div>
            <div class="card-body bg-light p-4">
                <form action="/taikhoan/sua/<%= taikhoan._id %>" method="POST">

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Tên đăng nhập</label>
                        <input type="text" class="form-control bg-secondary bg-opacity-10"
                            value="<%= taikhoan.TenDangNhap %>" disabled>
                        <small class="text-danger fst-italic">* Tên đăng nhập không thể thay đổi</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Họ và tên</label>
                        <input type="text" name="HoVaTen" class="form-control border-primary"
                            value="<%= taikhoan.HoVaTen %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Địa chỉ Email</label>
                        <input type="email" name="Email" class="form-control border-primary"
                            value="<%= taikhoan.Email %>" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-success">Cấp Quyền Hạn</label>
                        <select name="QuyenHan" class="form-select border-success fw-bold" required>
                            <option value="user" <%=taikhoan.QuyenHan==='user' ? 'selected' : '' %>>Khách hàng (User)
                            </option>

                            <option value="banhang" <%=taikhoan.QuyenHan==='banhang' ? 'selected' : '' %>>Nhân viên Bán
                                hàng</option>
                            <option value="thukho" <%=taikhoan.QuyenHan==='thukho' ? 'selected' : '' %>>Nhân viên Thủ
                                kho</option>

                            <option value="admin" <%=taikhoan.QuyenHan==='admin' ? 'selected' : '' %>>Quản trị viên
                                (Admin)</option>
                        </select>
                    </div>

                    <div class="text-center mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary px-5 fw-bold"><i class="bi bi-save"></i> Lưu Thay
                            Đổi</button>
                        <a href="/taikhoan" class="btn btn-secondary px-4 ms-2"><i class="bi bi-arrow-left"></i> Quay
                            lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>