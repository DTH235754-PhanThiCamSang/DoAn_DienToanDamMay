<%- include('navbar') %>

    <div class="container mt-4 mb-5">
        <h2 class="mb-4"><i class="bi bi-cart3 text-primary"></i> Giỏ hàng của bạn</h2>

        <% if (gioHang.length===0) { %>
            <div class="alert alert-warning text-center py-5 shadow-sm">
                <i class="bi bi-cart-x fs-1"></i>
                <p class="mt-3">Giỏ hàng đang trống.</p>
                <a href="/" class="btn btn-primary px-4">Quay về trang chủ mua sắm</a>
            </div>
            <% } else { %>
                <div class="row">
                    <div class="col-lg-8">
                        <% gioHang.forEach(sp=> { %>
                            <div class="card mb-3 shadow-sm border-0">
                                <div class="card-body">
                                    <div class="row align-items-center">
                                        <div class="col-1 text-center">
                                            <input type="checkbox" class="form-check-input chk-sanpham"
                                                data-gia="<%= sp.Gia %>" data-soluong="<%= sp.SoLuong %>" checked>
                                        </div>

                                        <div class="col-2 text-center">
                                            <img src="<%= sp.HinhAnh %>" class="img-fluid rounded"
                                                style="max-height: 80px;">
                                        </div>

                                        <div class="col-5">
                                            <h6 class="fw-bold mb-1">
                                                <%= sp.TenDT %>
                                            </h6>
                                            <div class="text-danger fw-bold">
                                                <%= (sp.Gia || 0).toLocaleString('vi-VN') %>đ
                                            </div>

                                            <div class="mt-2">
                                                <select class="form-select form-select-sm w-50 select-mau"
                                                    data-id="<%= sp.Id %>">
                                                    <% if(sp.DanhSachMau && sp.DanhSachMau.length> 0) { %>
                                                        <% sp.DanhSachMau.forEach(mau=> { %>
                                                            <option value="<%= mau %>" <%=sp.MauSac==mau ? 'selected'
                                                                : '' %>><%= mau %>
                                                            </option>
                                                            <% }) %>
                                                                <% } else { %>
                                                                    <option>
                                                                        <%= sp.MauSac %>
                                                                    </option>
                                                                    <% } %>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="col-4 text-end">
                                            <button class="btn btn-link text-danger p-0 mb-2"
                                                onclick="xoaSP('<%= sp.Id %>')">Xóa</button>
                                            <div class="input-group input-group-sm ms-auto" style="width: 100px;">
                                                <button class="btn btn-outline-secondary"
                                                    onclick="doiSoLuong('<%= sp.Id %>', -1)">-</button>
                                                <input type="text" class="form-control text-center bg-white"
                                                    value="<%= sp.SoLuong %>" readonly>
                                                <button class="btn btn-outline-secondary"
                                                    onclick="doiSoLuong('<%= sp.Id %>', 1)">+</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                    <div class="col-lg-4 mt-4 mt-lg-0">
                        <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4">Tóm tắt đơn hàng</h5>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Tạm tính:</span>
                                    <span id="tam-tinh-hien-thi" class="fw-bold">
                                        <%= tongTien.toLocaleString('vi-VN') %>đ
                                    </span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <span class="fw-bold fs-5">TỔNG TIỀN:</span>
                                    <span id="tong-tien-hien-thi" class="text-danger fw-bold fs-4">
                                        <%= tongTien.toLocaleString('vi-VN') %>đ
                                    </span>
                                </div>
                                <div class="d-grid gap-2">
                                    <a href="/thanhtoan" class="btn btn-primary btn-lg fw-bold shadow-sm">TIẾN HÀNH
                                        THANH TOÁN</a>
                                    <a href="/" class="btn btn-outline-secondary">Tiếp tục mua hàng</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
    </div>

    <%- include('footer') %>
        <script src="/script.js"></script>