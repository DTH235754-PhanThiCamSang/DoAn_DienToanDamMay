<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Lỗi Hệ Thống</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="card border-danger shadow">
            <div class="card-header bg-danger text-white fw-bold">CÓ LỖI XẢY RA!</div>
            <div class="card-body">
                <h4 class="text-danger">Thông báo: <%= message %></h4>
                <hr>
                <p>Chi tiết lỗi để sửa:</p>
                <pre class="bg-dark text-light p-3 rounded"><code><%= error.stack %></code></pre>
                <a href="/" class="btn btn-primary">Quay về Trang chủ</a>
            </div>
        </div>
    </div>
</body>
</html>